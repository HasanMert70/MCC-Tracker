<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.miracosta.cs112.controllers.HomeController">
   <children>
      <!-- I put the Logo on the top to make it look better -->
      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@../../../images/logo.png" />
         </image>
      </ImageView>
      <Label text="Welcome to MCC Tracker!" />

      <!-- These fields collect user profile information -->
      <TextField fx:id="nameField" promptText="Enter your name" maxWidth="220" />
      <TextField fx:id="ageField" promptText="Enter your age" maxWidth="220" />
      <TextField fx:id="goalField" promptText="Enter your goal" maxWidth="220" />
      <Button text="Create Profile" onAction="#handleCreateProfile" />
      <Label fx:id="profileLabel" text="No profile created yet." />
   </children>
</VBox>
